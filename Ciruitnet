        "import numpy as np\n",
        "\n",
        "def load_circuitnet_sample(path):\n",
        "    data = np.load(path)\n",
        "    # Features: macro_region, rudy, rudy_pin\n",
        "    x = np.stack([data['macro_region'], data['rudy'], data['rudy_pin']], axis=0)\n",
        "    # Label: IR-drop map\n",
        "    y = data['irdrop']\n",
        "    return torch.FloatTensor(x).unsqueeze(0), torch.FloatTensor(y).unsqueeze(0).unsqueeze(0)\n",
        "\n",
        "# Example training loop step\n",
        "model = FNO2d(modes1=12, modes2=12, width=32)\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=0.001)\n",
        "criterion = nn.MSELoss()\n",
        "\n",
        "x, y = load_circuitnet_sample('selected.csv')\n",
        "pred = model(x)\n",
        "loss = criterion(pred, y)"
      ],
