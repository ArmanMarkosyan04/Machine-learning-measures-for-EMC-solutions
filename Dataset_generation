        "# --- 1. INSTALLATION ---\n",
        "# We install the Neural ODE solver library first\n",
        "!pip install torchdiffeq\n",
        "\n",
        "# --- 2. IMPORTS ---\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "from torchdiffeq import odeint\n",
        "\n",
        "# DATASET GENERATION\n",
        "# We simulate a \"Victim\" wire voltage trace caused by an \"Aggressor\" pulse.\n",
        "# This acts as our \"Open Source Dataset\" proxy to ensure the code runs for you immediately.\n",
        "def generate_crosstalk_data():\n",
        "    t = np.linspace(0, 10, 100)\n",
        "    # Physics: A damped oscillation typical of inductive/capacitive coupling\n",
        "    voltage_victim = 0.5 * np.sin(2 * t) * np.exp(-0.3 * t)\n",
        "    # Add some random noise to make it \"real\" lab data\n",
        "    noise = np.random.normal(0, 0.02, 100)\n",
        "    return t, voltage_victim + noise\n",
        "\n",
        "print(\"Generating Synthetic Crosstalk Dataset...\")\n",
        "time_obs, voltage_obs = generate_crosstalk_data()\n",
        "\n",
        "# --- 4. DATA PREPARATION (THE FIX IS HERE) ---\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "\n",
        "# CRITICAL FIX: We add .float() to convert Double (float64) to Float (float32)\n",
        "# This matches the Neural Network weights.\n",
        "y_true = torch.tensor(voltage_obs).float().to(device).reshape(-1, 1, 1)\n",
        "t_tensor = torch.tensor(time_obs).float().to(device)\n",
        "y0 = y_true[0] # Initial condition (Voltage at t=0)\n",
        "\n",
        "# --- 5. THE NEURAL ODE MODEL ---\n",
        "# This model learns the \"Telegrapher's Equations\" hidden inside the data\n",
        "class ODEFunc(nn.Module):\n",
        "    def __init__(self):\n",
        "        super(ODEFunc, self).__init__()\n",
        "        # A simple network that represents dy/dt = f(y, t)\n",
        "        self.net = nn.Sequential(\n",
        "            nn.Linear(1, 50),\n",
        "            nn.Tanh(),\n",
        "            nn.Linear(50, 1)\n",
        "        )\n",
        "\n",
        "    def forward(self, t, y):\n",
        "        # The ODE solver passes 'y' as float32, so this works now\n",
        "        return self.net(y)\n",
        "\n",
        "# --- 6. TRAINING ---\n",
        "func = ODEFunc().to(device)\n",
        "optimizer = torch.optim.Adam(func.parameters(), lr=0.01)\n",
        "\n",
        "print(\"Starting Neural ODE Training (fitting the differential equation)...\")\n",
        "\n",
        "loss_history = []\n",
        "\n",
        "for itr in range(1, 201): # Train for 200 iterations\n",
        "    optimizer.zero_grad()\n",
        "\n",
        "    # Forward pass: Integrate the Neural ODE from t=0 to t=10\n",
        "    pred_y = odeint(func, y0, t_tensor)\n",
        "\n",
        "    # Calculate error between Model Prediction and \"Real\" Data\n",
        "    loss = torch.mean(torch.abs(pred_y - y_true))\n",
        "    loss.backward()\n",
        "    optimizer.step()\n",
        "\n",
        "    loss_history.append(loss.item())\n",
        "    if itr % 20 == 0:\n",
        "        print(f'Iter {itr:03d} | Loss: {loss.item():.6f}')\n",
        "\n",
        "# --- 7. VISUALIZATION ---\n",
        "# Predict the full curve using the trained physics model\n",
        "with torch.no_grad():\n",
        "    predicted_voltage = odeint(func, y0, t_tensor).cpu().numpy().flatten()\n",
        "\n",
        "plt.figure(figsize=(12, 5))\n",
        "\n",
        "# Plot 1: The Fit\n",
        "plt.subplot(1, 2, 1)\n",
        "plt.plot(time_obs, voltage_obs, 'ko', label='Measured Crosstalk (Data)', alpha=0.6)\n",
        "plt.plot(time_obs, predicted_voltage, 'r-', linewidth=2, label='Neural ODE (AI Model)')\n",
        "plt.title(\"EMC Crosstalk Prediction\")\n",
        "plt.xlabel(\"Time (ns)\")\n",
        "plt.ylabel(\"Voltage (V)\")\n",
        "plt.legend()\n",
        "plt.grid(True)\n",
        "\n",
        "# Plot 2: The Training Convergence\n",
        "plt.subplot(1, 2, 2)\n",
        "plt.plot(loss_history, 'b-')\n",
        "plt.title(\"Model Convergence (Loss)\")\n",
        "plt.xlabel(\"Iteration\")\n",
        "plt.ylabel(\"Error\")\n",
        "plt.grid(True)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
