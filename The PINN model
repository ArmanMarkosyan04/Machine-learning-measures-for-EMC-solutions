        "import torch\n",
        "import torch.nn as nn\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# --- 1. THE PINN MODEL ---\n",
        "# A simple neural network that takes (x, t) and predicts Voltage (u)\n",
        "class PINN(nn.Module):\n",
        "    def __init__(self):\n",
        "        super(PINN, self).__init__()\n",
        "        # Input: 2 coordinates (Location x, Time t)\n",
        "        # Output: 1 value (Voltage u)\n",
        "        self.net = nn.Sequential(\n",
        "            nn.Linear(2, 50),\n",
        "            nn.Tanh(),\n",
        "            nn.Linear(50, 50),\n",
        "            nn.Tanh(),\n",
        "            nn.Linear(50, 50),\n",
        "            nn.Tanh(),\n",
        "            nn.Linear(50, 1)\n",
        "        )\n",
        "\n",
        "    def forward(self, x, t):\n",
        "        # Concatenate x and t to form the input (N, 2)\n",
        "        input_data = torch.cat([x, t], dim=1)\n",
        "        return self.net(input_data)\n",
        "\n",
        "# --- 2. THE PHYSICS (Maxwell/Wave Equation) ---\n",
        "def physics_loss(model, x, t):\n",
        "    # Enable gradient tracking for Physics derivatives\n",
        "    x.requires_grad = True\n",
        "    t.requires_grad = True\n",
        "\n",
        "    u = model(x, t)\n",
        "\n",
        "    # First derivatives (du/dx, du/dt)\n",
        "    u_x = torch.autograd.grad(u, x, torch.ones_like(u), create_graph=True)[0]\n",
        "    u_t = torch.autograd.grad(u, t, torch.ones_like(u), create_graph=True)[0]\n",
        "\n",
        "    # Second derivatives (d2u/dx2, d2u/dt2)\n",
        "    u_xx = torch.autograd.grad(u_x, x, torch.ones_like(u_x), create_graph=True)[0]\n",
        "    u_tt = torch.autograd.grad(u_t, t, torch.ones_like(u_t), create_graph=True)[0]\n",
        "\n",
        "    # The Wave Equation: u_tt = c^2 * u_xx\n",
        "    # We set speed of light c = 1 for simplicity\n",
        "    c = 1.0\n",
        "    residual = u_tt - (c**2) * u_xx\n",
        "\n",
        "    # The loss is the \"error\" in the equation. Ideally, it should be 0.\n",
        "    return torch.mean(residual**2)\n",
        "\n",
        "# --- 3. TRAINING DATA (Collocation Points) ---\n",
        "# We don't need a CSV. We just pick random points in space and time.\n",
        "N_physics = 2000\n",
        "x_physics = torch.rand(N_physics, 1) # x between 0 and 1\n",
        "t_physics = torch.rand(N_physics, 1) # t between 0 and 1\n",
        "\n",
        "# Boundary Conditions (BC): The wire is grounded at ends\n",
        "# u(0, t) = 0 and u(1, t) = 0\n",
        "N_bc = 200\n",
        "t_bc = torch.rand(N_bc, 1)\n",
        "x_bc_left = torch.zeros(N_bc, 1)\n",
        "x_bc_right = torch.ones(N_bc, 1)\n",
        "u_bc_fixed = torch.zeros(N_bc, 1) # Voltage is 0 at ends\n",
        "\n",
        "# Initial Conditions (IC): A Gaussian Pulse at t=0\n",
        "# u(x, 0) = sin(pi*x)\n",
        "N_ic = 200\n",
        "x_ic = torch.rand(N_ic, 1)\n",
        "t_ic = torch.zeros(N_ic, 1)\n",
        "u_ic_val = torch.sin(np.pi * x_ic)\n",
        "\n",
        "# --- 4. TRAINING LOOP ---\n",
        "model = PINN()\n",
        "optimizer = torch.optim.Adam(model.parameters(), lr=0.001)\n",
        "\n",
        "print(\"Training PINN (Learning the Wave Equation without Data)...\")\n",
        "\n",
        "for epoch in range(3001):\n",
        "    optimizer.zero_grad()\n",
        "\n",
        "    # Loss 1: Physics Loss (The Equation)\n",
        "    loss_pde = physics_loss(model, x_physics, t_physics)\n",
        "\n",
        "    # Loss 2: Boundary Conditions (Grounding)\n",
        "    u_pred_left = model(x_bc_left, t_bc)\n",
        "    u_pred_right = model(x_bc_right, t_bc)\n",
        "    loss_bc = torch.mean((u_pred_left - u_bc_fixed)**2) + torch.mean((u_pred_right - u_bc_fixed)**2)\n",
        "\n",
        "    # Loss 3: Initial Condition (The starting Pulse)\n",
        "    u_pred_ic = model(x_ic, t_ic)\n",
        "    loss_ic = torch.mean((u_pred_ic - u_ic_val)**2)\n",
        "\n",
        "    # Total Loss\n",
        "    total_loss = loss_pde + loss_bc + loss_ic\n",
        "\n",
        "    total_loss.backward()\n",
        "    optimizer.step()\n",
        "\n",
        "    if epoch % 500 == 0:\n",
        "        print(f\"Epoch {epoch} | Total Loss: {total_loss.item():.5f} (PDE: {loss_pde.item():.5f})\")\n",
        "\n",
        "# --- 5. RESULT VISUALIZATION ---\n",
        "# Create a grid to visualize the field\n",
        "x_test = torch.linspace(0, 1, 100)\n",
        "t_test = torch.linspace(0, 1, 100)\n",
        "X, T = torch.meshgrid(x_test, t_test)\n",
        "X_flat = X.reshape(-1, 1)\n",
        "T_flat = T.reshape(-1, 1)\n",
        "\n",
        "with torch.no_grad():\n",
        "    U_pred = model(X_flat, T_flat).reshape(100, 100)\n",
        "\n",
        "plt.figure(figsize=(8, 6))\n",
        "# Using imshow to show the propagation of the wave over time\n",
        "plt.imshow(U_pred.numpy(), extent=[0, 1, 0, 1], origin='lower', cmap='RdBu', aspect='auto')\n",
        "plt.colorbar(label='Voltage (u)')\n",
        "plt.title(\"PINN Solution: Wave Propagation on a Wire\")\n",
        "plt.xlabel(\"Time (t)\")\n",
        "plt.ylabel(\"Position on Wire (x)\")\n",
        "plt.show()"
      ]
